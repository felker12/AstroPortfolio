---
import Layout from '@layouts/Layout.astro';
import Footer from '@components/Footer.astro';

// Structured projects array with your newly added GitHub repositories
const projects = [
  {
    title: "Portfolio Generator",
    subtitle: "Full-Stack Document Automation Platform",
    tags: ["C#", "React", "TypeScript", ".NET Aspire", "Minimal API", "Azure", "GitHub Actions"],
    description: "A full-stack application that parses standard Microsoft Word (.docx) resumes and compiles them automatically into production-ready, multi-page portfolio websites.",
    features: [
      "Built high-performance RESTful API endpoints using ASP.NET Minimal API for document schema parsing and zip file payload delivery.",
      "Engineered an isolation rendering engine using React and TypeScript to safely preview generated themes via an internal iframe canvas.",
      "Architected microservice orchestration utilizing .NET Aspire to streamline cloud deployment readiness and local multi-project routing.",
      "Integrated automated CI/CD workflows with GitHub Actions to build frontend modules, compile the .NET core project, and target Azure App Service instances."
    ],
    links: {
      github: "https://github.com/felker12/PortfolioSiteCreator",
      demo: "#" // Replace with live link when active
    }
  },
  {
    title: "Time Punch Management System",
    subtitle: "Enterprise Workforce Tracking Application",
    tags: ["C#", "React", "TypeScript", "ASP.NET Core", ".NET Aspire", "SQL Server", "Azure"],
    description: "A secure, enterprise-grade attendance tracking ecosystem providing role-based administration dashboards and audit logs for workforce optimization.",
    features: [
      "Designed secure user authentication layers and granular role-based access tokens (RBAC) handling cross-origin employee clock-in/out workflows.",
      "Engineered clean database schemas inside SQL Server utilizing explicit entity relationships, indexing, and strict relational constraints.",
      "Constructed custom admin tools to compile live attendance reports, track time validation discrepancies, and output management dashboards.",
      "Automated complete environmental builds to Azure App Service hosting platforms leveraging multi-stage continuous integrations."
    ],
    links: {
      github: "https://github.com/felker12/TimePunchSite",
      demo: null
    }
  },
  {
    title: "Modular 2D RPG Engine",
    subtitle: "High-Performance Architecture Project",
    tags: ["C#", "MonoGame", "xUnit.net", "XML", "WinForms"],
    description: "A decoupled, data-driven 2D game engine encompassing over 10,000 lines of original source code built to optimize modular game state execution frameworks.",
    features: [
      "Architected clean system separation isolating render context states, user input listeners, internal state controllers, and physics calculators.",
      "Constructed a companion desktop mapping and item compiler utility in WinForms, decreasing custom entity content creation overhead by roughly 30%.",
      "Engineered flexible save-state serializations via structured XML serialization schemas ensuring robust file layout integrity.",
      "Authored a robust automated test layer using xUnit to validate regression security throughout highly iterative memory handling layers."
    ],
    links: {
      github: "https://github.com/felker12/SkeletonsAdventure",
      demo: null
    }
  },
  {
    title: "Legacy Personal Portfolio",
    subtitle: "DevOps Workflow Retrofitting",
    tags: ["C#", "ASP.NET Framework 4.8", "Azure", "GitHub Actions"],
    description: "A legacy systems automation project focusing on configuring modern containerless continuous deployment pipelines for framework-dependent software suites.",
    features: [
      "Retrofitted an established .NET Framework codebase into fully automated workflow structures utilizing remote environment runners.",
      "Programmed deployment sequences targeting scalable cloud pipelines without breaking server-side framework assumptions."
    ],
    links: {
      github: "https://github.com/felker12/PortfolioWebsite",
      demo: "https://anthonyfelker.com"
    }
  }
];
---

<Layout>
    <div class="max-w-6xl mx-auto px-4 py-16 md:py-24">
        
        <!-- Page Title & Header Context -->
        <div class="text-center mb-16">
            <h1 class="text-4xl md:text-5xl font-light text-white mb-4 tracking-tight">
                Featured <span class="text-cyan-400 font-normal">Projects</span>
            </h1>
            <p class="text-slate-400 max-w-xl mx-auto text-sm md:text-base leading-relaxed">
                A selection of full-stack systems, architectural frameworks, and DevOps pipelines highlighting scalable design patterns and clean implementations.
            </p>
        </div>

        <!-- Projects Grid Layout -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
            {projects.map((project) => (
                <div class="flex flex-col bg-black/50 border border-slate-800/90 shadow-xl 
                            rounded-xl backdrop-blur-sm p-6 md:p-8 justify-between min-h-full 
                            hover:border-slate-700/60 hover:-translate-y-1 transition-all duration-300 ease-out">
                    <div>
                        <!-- Project Headers -->
                        <div class="mb-4">
                            <h2 class="text-2xl font-semibold text-white tracking-tight">{project.title}</h2>
                            <p class="text-xs text-cyan-400 font-mono tracking-wider mt-1 uppercase">{project.subtitle}</p>
                        </div>

                        <!-- Technical Tags Cloud -->
                        <div class="flex flex-wrap gap-1.5 mb-6">
                            {project.tags.map((tag) => (
                                <span class="bg-slate-950/60 border border-slate-800/80 text-slate-300 font-mono text-[11px] px-2.5 py-0.5 rounded">
                                    {tag}
                                </span>
                            ))}
                        </div>

                        <!-- Core Project Narrative -->
                        <p class="text-slate-300 text-sm leading-relaxed mb-6">
                            {project.description}
                        </p>

                        <!-- Engineering Key Highlights Bullet Points -->
                        <div class="border-t border-slate-800/60 pt-5 mt-2 mb-8">
                            <h3 class="text-xs font-semibold text-slate-400 tracking-wider uppercase mb-3 flex items-center gap-1.5">
                                <span class="w-1 h-3 bg-cyan-500 rounded-sm"></span> Architectural Highlights
                            </h3>
                            <ul class="space-y-2.5 text-xs text-slate-400 list-none pl-0">
                                {project.features.map((feature) => (
                                    <li class="flex items-start gap-2.5 leading-relaxed">
                                        <span class="text-cyan-500 text-sm leading-none mt-0.5">▪</span>
                                        <span>{feature}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    </div>

                    <!-- Action Link Routing Layer -->
                    <div class="flex flex-wrap gap-4 border-t border-slate-800/40 pt-4 mt-auto">
                        {project.links.github && (
                            <a 
                                href={project.links.github} 
                                target="_blank"
                                rel="noopener noreferrer"
                                class="flex-1 inline-flex items-center justify-center gap-2 border border-slate-700 hover:border-slate-500 hover:bg-slate-900/50 text-slate-200 text-xs font-medium px-4 py-2.5 rounded-lg transition-all duration-200 text-center"
                            >
                                <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z" />
                                </svg>
                                Code Repository
                            </a>
                        )}
                        {project.links.demo && (
                            <a 
                                href={project.links.demo}
                                target="_blank"
                                rel="noopener noreferrer" 
                                class="flex-1 inline-flex items-center justify-center gap-1.5 bg-cyan-600 hover:bg-cyan-500 hover:scale-[1.03] text-white text-xs font-medium px-4 py-2.5 rounded-lg transition-all duration-300 text-center shadow-md shadow-cyan-950/20"
                            >
                                Launch Application
                                <svg class="w-3 h-3 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                                </svg>
                            </a>
                        )}
                    </div>
                </div>
            ))}
        </div>

        <!-- Contact Bridge -->
        <div class="mt-20 text-center border-t border-slate-800/60 pt-16">
            <h3 class="text-xl font-light text-slate-300 mb-4">Want to dive deeper into the code architecture?</h3>
            <a 
                href="/contact" 
                class="inline-block border border-cyan-500/30 text-cyan-400 hover:bg-cyan-500/10 text-xs font-mono tracking-wider px-5 py-3 rounded-lg transition-colors duration-200"
            >
                GET_IN_TOUCH.exe
            </a>
        </div>

        <Footer />
    </div>
</Layout>