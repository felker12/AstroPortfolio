---
import Layout from '@layouts/Layout.astro';
import Footer from '@components/Footer.astro';

const screenshotroot = "/projectpics/timepunch/";

const screenshots = [
  { src: `${screenshotroot}homepage.png`, width: 1920, height: 1080, alt: "Time Punch application landing page" },
  { src: `${screenshotroot}login.png`, width: 1920, height: 1080, alt: "Time Punch login screen" },
  { src: `${screenshotroot}history.png`, width: 1920, height: 1080, alt: "Employee shift history screen" },
  { src: `${screenshotroot}dash.png`, width: 1920, height: 1080, alt: "Employee dashboard screen" },
  { src: `${screenshotroot}admindash.png`, width: 1920, height: 1080, alt: "Admin dashboard overview" },
  { src: `${screenshotroot}admindash2.png`, width: 1920, height: 1080, alt: "Admin reporting screen" },
];

const visibleScreenshots = screenshots.filter((pic) => pic.src.trim() !== "");

const tags = ["C#", "React", "TypeScript", "ASP.NET Core", ".NET Aspire", "SQL Server", "Azure"];

const features = [
  {
    title: "Employee Authentication",
    desc: "Supports secure sign-in workflows with separate access levels for employees and administrators."
  },
  {
    title: "Clock In / Clock Out Workflow",
    desc: "Allows employees to start and end shifts while tracking timestamps and maintaining shift history."
  },
  {
    title: "Attendance Dashboard",
    desc: "Provides a responsive React interface for viewing current status, shift history, and worked time."
  },
  {
    title: "Administrative Reporting",
    desc: "Gives administrators tools to review attendance records, identify discrepancies, and support payroll review."
  },
  {
    title: "SQL Server Persistence",
    desc: "Stores users, shifts, and time entries using a relational SQL Server database structure."
  },
  {
    title: "Responsive Interface",
    desc: "Built with a responsive layout so the application can be used comfortably on desktop and tablet-sized screens."
  }
];
---

<Layout>
    <div class="max-w-5xl mx-auto px-4 py-16 md:py-24">

        <div class="mb-8">
            <a href="/projects" class="inline-flex items-center gap-2 text-xs font-mono text-slate-500 hover:text-cyan-400 transition-colors duration-200">
                <svg class="w-3 h-3 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                </svg>
                Back to Projects
            </a>
        </div>

        <section class="mb-16">
            <p class="text-cyan-400 font-mono text-xs uppercase tracking-widest">
                Full-Stack Web Application
            </p>

            <h1 class="text-4xl md:text-5xl font-light text-white mt-2 mb-4 tracking-tight">
                Time Punch Management System
            </h1>

            <p class="text-md md:text-lg text-slate-300 max-w-3xl leading-relaxed mb-6">
                A full-stack employee attendance application designed to manage clock-in and clock-out workflows,
                store shift history, and provide administrative reporting through a React frontend and ASP.NET Core backend.
            </p>

            <div class="flex flex-wrap gap-1.5 mb-8">
                {tags.map((tag) => (
                    <span class="bg-slate-950/60 border border-slate-800/80 text-slate-300 font-mono text-[11px] px-2.5 py-0.5 rounded">
                        {tag}
                    </span>
                ))}
            </div>

            <div class="flex flex-wrap gap-4">
                <a 
                    href="https://github.com/felker12/TimePunchSite" 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="inline-flex items-center gap-2 border border-slate-700 hover:border-slate-500 hover:bg-slate-900/50 text-slate-200 text-xs font-medium px-5 py-2.5 rounded-lg transition-all duration-200"
                >
                    <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z" />
                    </svg>
                    Code Repository
                </a>
            </div>
        </section>

        <div id="timepunch-gallery">
            
            {visibleScreenshots[0] && (
                <section class="mb-20">
                    <a 
                        href={visibleScreenshots[0].src}
                        data-pswp-width={visibleScreenshots[0].width}
                        data-pswp-height={visibleScreenshots[0].height}
                        target="_blank"
                        rel="noreferrer"
                        class="group block bg-black/40 border border-slate-800/90 rounded-xl p-2 backdrop-blur-sm shadow-2xl 
                        transition-all duration-300 hover:border-slate-700/60 hover:scale-105"
                    >
                        <div class="overflow-hidden rounded-lg relative">
                            <img
                                src={visibleScreenshots[0].src}
                                alt={visibleScreenshots[0].alt}
                                class="w-full object-cover transform duration-500 ease-out group-hover:scale-[1.01]"
                            />
                            <div class="absolute bottom-4 right-4 bg-slate-950/80 border border-slate-800/80 backdrop-blur px-3 py-1.5 rounded text-[10px] font-mono text-slate-400 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                                View Larger
                            </div>
                        </div>
                    </a>
                </section>
            )}

            <section class="mb-20 grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
                <div class="md:col-span-1">
                    <h2 class="text-xl font-semibold text-white tracking-tight flex items-center gap-2">
                        <span class="w-1 h-4 bg-cyan-500 rounded-sm"></span> Project Overview
                    </h2>
                    <p class="text-xs text-slate-500 font-mono mt-1 uppercase">Context & Purpose</p>
                </div>

                <div class="md:col-span-2 text-slate-300 text-sm leading-relaxed space-y-4">
                    <p>
                        This project was built around a practical business workflow: employee time tracking. The goal was to create an application where employees could record attendance and administrators could review time data in a structured interface.
                    </p>
                    <p>
                        Building it gave me more experience connecting a React and TypeScript frontend to an ASP.NET Core backend, designing API endpoints, working with SQL Server data, and organizing services with .NET Aspire.
                    </p>
                </div>
            </section>

            <section class="mb-20 border-t border-slate-800/60 pt-16">
                <div class="mb-10">
                    <h2 class="text-xl font-semibold text-white tracking-tight flex items-center gap-2">
                        <span class="w-1 h-4 bg-cyan-500 rounded-sm"></span> Key Features
                    </h2>
                    <p class="text-xs text-slate-500 font-mono mt-1 uppercase">Application Functionality</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    {features.map((f) => (
                        <div class="bg-black/30 border border-slate-800/80 p-5 rounded-xl hover:border-slate-700/50
                         transition-colors duration-200 hover:scale-105">
                            <h3 class="text-sm font-semibold text-white mb-2 flex items-center gap-1.5">
                                <span class="text-cyan-400 font-mono text-xs">▪</span> {f.title}
                            </h3>
                            <p class="text-slate-400 text-xs leading-relaxed">{f.desc}</p>
                        </div>
                    ))}
                </div>
            </section>

            {visibleScreenshots.length > 1 && (
                <section class="mb-20 border-t border-slate-800/60 pt-16">
                    <div class="mb-10">
                        <h2 class="text-xl font-semibold text-white tracking-tight flex items-center gap-2">
                            <span class="w-1 h-4 bg-cyan-500 rounded-sm"></span> Application Screenshots
                        </h2>
                        <p class="text-xs text-slate-500 font-mono mt-1 uppercase">Interface Preview</p>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
                        {visibleScreenshots.slice(1).map((pic, i) => (
                            <a 
                                href={pic.src}
                                data-pswp-width={pic.width}
                                data-pswp-height={pic.height}
                                target="_blank"
                                rel="noreferrer"
                                class="group bg-black/40 border border-slate-800/90 rounded-xl p-1.5 shadow-lg block 
                                hover:border-slate-700/60 hover:scale-110 transition-transform duration-300"
                            >
                                <div class="overflow-hidden rounded-lg relative">
                                    <img 
                                        src={pic.src} 
                                        alt={pic.alt} 
                                        class="w-full h-auto object-cover transform duration-300 group-hover:scale-[1.03]" 
                                    />
                                    <div class="absolute inset-0 bg-cyan-950/10 opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex items-center justify-center">
                                        <span class="bg-slate-900/90 border border-slate-800 text-[10px] font-mono text-cyan-400 px-2 py-1 rounded">
                                            View Screenshot {i + 2}
                                        </span>
                                    </div>
                                </div>
                            </a>
                        ))}
                    </div>
                </section>
            )}
        </div>

        <section class="mb-20 border-t border-slate-800/60 pt-16 grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-1">
                <h2 class="text-xl font-semibold text-white tracking-tight flex items-center gap-2">
                    <span class="w-1 h-4 bg-cyan-500 rounded-sm"></span> Technical Highlights
                </h2>
                <p class="text-xs text-slate-500 font-mono mt-1 uppercase">Stack Implementation</p>
            </div>
            
            <div class="lg:col-span-2 space-y-6">
                <div class="border-b border-slate-900 pb-4">
                    <h3 class="text-sm font-mono text-cyan-400 font-semibold mb-1">ASP.NET Core APIs</h3>
                    <p class="text-slate-300 text-xs leading-relaxed">
                        Built API endpoints for employee attendance actions, authentication workflows, and administrative data access.
                    </p>
                </div>

                <div class="border-b border-slate-900 pb-4">
                    <h3 class="text-sm font-mono text-cyan-400 font-semibold mb-1">SQL Server Data Model</h3>
                    <p class="text-slate-300 text-xs leading-relaxed">
                        Designed relational tables for users, shifts, and time entries so attendance data could be stored and queried consistently.
                    </p>
                </div>

                <div>
                    <h3 class="text-sm font-mono text-cyan-400 font-semibold mb-1">React + TypeScript Frontend</h3>
                    <p class="text-slate-300 text-xs leading-relaxed">
                        Developed dashboard views with reusable React components and TypeScript types to improve reliability across frontend data handling.
                    </p>
                </div>
            </div>
        </section>

        <section class="mb-20 border-t border-slate-800/60 pt-16 grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-1">
                <h2 class="text-xl font-semibold text-white tracking-tight flex items-center gap-2">
                    <span class="w-1 h-4 bg-cyan-500 rounded-sm"></span> Challenges & Lessons Learned
                </h2>
                <p class="text-xs text-slate-500 font-mono mt-1 uppercase">Problem Solving</p>
            </div>

            <div class="lg:col-span-2 text-slate-300 text-sm leading-relaxed">
                <ul class="space-y-3.5 text-xs text-slate-400 list-none pl-0">
                    <li class="flex items-start gap-2.5 leading-relaxed">
                        <span class="text-cyan-500 text-md leading-none mt-0.5">▪</span>
                        <span><strong>State Management:</strong> Learned how important it is to keep frontend state aligned with backend attendance records.</span>
                    </li>
                    <li class="flex items-start gap-2.5 leading-relaxed">
                        <span class="text-cyan-500 text-md leading-none mt-0.5">▪</span>
                        <span><strong>Authentication Flow:</strong> Gained more experience handling login state, protected routes, and role-based access in a full-stack application.</span>
                    </li>
                    <li class="flex items-start gap-2.5 leading-relaxed">
                        <span class="text-cyan-500 text-md leading-none mt-0.5">▪</span>
                        <span><strong>Local Orchestration:</strong> Used .NET Aspire to organize the frontend and backend services during local development.</span>
                    </li>
                </ul>
            </div>
        </section>

        <section class="mb-20 border-t border-slate-800/60 pt-16 grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-1">
                <h2 class="text-xl font-semibold text-white tracking-tight flex items-center gap-2">
                    <span class="w-1 h-4 bg-cyan-500 rounded-sm"></span> Future Improvements
                </h2>
                <p class="text-xs text-slate-500 font-mono mt-1 uppercase">Planned Enhancements</p>
            </div>

            <div class="lg:col-span-2">
                <div class="bg-black/20 border border-slate-900 rounded-xl p-6 hover:scale-105 transition-transform duration-300">
                    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-xs text-slate-400 list-none pl-0">
                        <li class="flex items-center gap-2">
                            <span class="text-cyan-500 font-mono">01//</span> Password recovery workflow
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="text-cyan-500 font-mono">02//</span> Email notifications
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="text-cyan-500 font-mono">03//</span> Manager approval workflows
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="text-cyan-500 font-mono">04//</span> Calendar-style attendance view
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="text-cyan-500 font-mono">05//</span> Payroll CSV export
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="text-cyan-500 font-mono">06//</span> Deployment improvements
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="text-center border-t border-slate-800/60 pt-12">
            <a 
                href="/projects" 
                class="inline-block border border-cyan-500/30 text-cyan-400 hover:bg-cyan-500/10 text-xs font-mono tracking-wider px-5 py-3 rounded-lg transition-colors duration-200"
            >
                Back to Projects
            </a>
        </section>

        <Footer />
    </div>
</Layout>

<script>
    import PhotoSwipeLightbox from 'photoswipe/lightbox';
    import 'photoswipe/style.css';

    const lightbox = new PhotoSwipeLightbox({
        gallery: '#timepunch-gallery',
        children: 'a',
        pswpModule: () => import('photoswipe')
    });
    
    lightbox.init();
</script>