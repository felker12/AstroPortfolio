---
import Layout from "@layouts/Layout.astro";
import Footer from "@components/Footer.astro";
import ContactForm from "@components/ContactForm.astro";
---

<Layout>
    <div class="max-w-6xl mx-auto px-4 py-16 md:py-24">
        
        <!-- Section Header -->
        <div class="text-center mb-16">
            <h1 class="text-4xl md:text-5xl font-light text-white mb-4 tracking-tight">
                Get In <span class="text-cyan-400 font-normal">Touch</span>
            </h1>
            <p class="text-slate-400 max-w-xl mx-auto text-sm md:text-base leading-relaxed">
                Have an engineering problem to solve, a development position open, or a project that needs technical direction? Reach out below.
            </p>
        </div>

        <!-- Asymmetrical Two-Column Matrix -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            
            <!-- Left Side: Directory / Quick Connections -->
            <div class="lg:col-span-5 space-y-4">
                
                <!-- Routing Context Card -->
                <div class="bg-black/50 border border-slate-800/90 shadow-xl p-6 rounded-xl backdrop-blur-sm">
                    <h2 class="text-xs font-semibold text-cyan-400 uppercase tracking-wider mb-2 font-mono">DIRECT_ROUTING</h2>
                    <p class="text-slate-300 text-sm leading-relaxed">
                        To maintain secure system tracking, please utilize the automated contact gateway on the right. All form submissions are routed directly to my active inbox.
                    </p>
                </div>

                <!-- GitHub Profile Card -->
                <div class="bg-black/50 border border-slate-800/90 p-5 rounded-xl backdrop-blur-sm flex items-center gap-4">
                    <!-- Clickable Icon Wrapper -->
                    <a 
                        href="https://github.com/felker12" 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="p-2.5 bg-slate-900/60 border border-slate-800 rounded-lg text-cyan-400 shadow-inner shrink-0 hover:border-cyan-500/50 hover:text-cyan-300 hover:bg-slate-900/90 transition-all duration-200"
                        title="Open GitHub Profile"
                    >
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                            <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z" />
                        </svg>
                    </a>
                    <div>
                        <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-wider font-mono">Source Control</h3>
                        <a href="https://github.com/felker12" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-white hover:text-cyan-400 transition-colors duration-200">
                            github.com/felker12
                        </a>
                    </div>
                </div>

                <!-- Location Card -->
                <div class="bg-black/50 border border-slate-800/90 p-5 rounded-xl backdrop-blur-sm flex items-center gap-4">
                    <!-- Clickable Icon Wrapper -->
                    <a 
                        href="https://www.google.com/maps/place/Quality+Roofing+of+Indiana+LLC/@39.506166,-87.3578661,16.08z" 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="p-2.5 bg-slate-900/60 border border-slate-800 rounded-lg text-cyan-400 shadow-inner shrink-0 hover:border-cyan-500/50 hover:text-cyan-300 hover:bg-slate-900/90 transition-all duration-200"
                        title="Open Map Location"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25a7.5 7.5 0 1 1 15 0Z" />
                        </svg>
                    </a>
                    <div>
                        <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-wider font-mono">Base Region</h3>
                        <a href="https://www.google.com/maps/place/Quality+Roofing+of+Indiana+LLC/@39.506166,-87.3578661,16.08z" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-white hover:text-cyan-400 transition-colors duration-200">
                            Terre Haute / Greater Indianapolis
                        </a>
                    </div>
                </div>

            </div>

            <!-- Right Side: Contact Form Card -->
            <div class="lg:col-span-7 bg-black/50 border border-slate-800/90 shadow-xl p-6 md:p-8 rounded-xl backdrop-blur-sm">
                <h2 class="text-xl font-semibold text-white mb-6 tracking-tight flex items-center gap-2">
                    <span class="w-1.5 h-5 bg-cyan-500 rounded-full inline-block"></span>
                    Send a Message
                </h2>
                <ContactForm />
            </div>
        </div>
        <Footer />
    </div>
</Layout>