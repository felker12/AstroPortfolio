---
import Layout from '@layouts/Layout.astro';
import Footer from '@components/Footer.astro';

// Structured skills data for clean rendering loops
const skillCategories = [
  {
    title: "Languages",
    skills: ["C#", "TypeScript", "JavaScript", "SQL (SQL Server)", "HTML5", "CSS3", "XML", "Java"]
  },
  {
    title: "Frameworks & Libraries",
    skills: ["ASP.NET Core", ".NET Core", "Astro", "React", "Tailwind CSS", "MonoGame", "xUnit"]
  },
  {
    title: "Cloud & DevOps",
    skills: ["Azure App Services", "Netlify", "GitHub Actions", "Git"]
  },
  {
    title: "Architecture & Concepts",
    skills: ["OOP", "REST APIs", "API Integration", "System Design", "Testing", "Agile/Scrum", "Authentication"]
  }
];
---

<Layout>
    <div class="max-w-4xl mx-auto px-4 py-16 md:py-24 text-left">
        
        <!-- Page Title -->
        <h1 class="text-4xl md:text-5xl font-light text-white mb-8 tracking-tight text-center md:text-left">
            About <span class="text-cyan-400 font-normal">Me</span>
        </h1>

        <!-- Professional Summary Panel -->
        <section class="bg-black/50 border border-slate-800/90 shadow-lg p-6 md:p-8 rounded-xl backdrop-blur-sm mb-12">
            <h2 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
                Professional Summary
            </h2>
            <p class="text-slate-300 text-base leading-relaxed">
                Software Engineer with professional experience developing and maintaining production websites and building full-stack .NET applications. Experienced with ASP.NET Core, C#, React, Astro, SQL Server, Azure, GitHub Actions, and modern CI/CD workflows. Strong foundation in object-oriented design, REST APIs, debugging, testing, and scalable software architecture.
            </p>
        </section>

        <!-- Technical Skills Grid -->
        <section class="mb-12">
            <h2 class="text-2xl font-light text-white mb-6 tracking-tight flex items-center gap-2">
                Technical Expertise
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {skillCategories.map((category) => (
                    <div class="bg-black/30 border border-slate-800/60 p-5 rounded-xl backdrop-blur-sm">
                        <h3 class="text-sm font-semibold text-cyan-400 uppercase tracking-wider mb-3">
                            {category.title}
                        </h3>
                        <div class="flex flex-wrap gap-2">
                            {category.skills.map((skill) => (
                                <span class="bg-slate-900/80 border border-slate-800 text-slate-300 text-xs px-2.5 py-1 rounded-md font-mono">
                                    {skill}
                                </span>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- Professional Experience Timeline -->
        <section class="mb-12">
            <h2 class="text-2xl font-light text-white mb-6 tracking-tight">
                Professional Experience
            </h2>
            <div class="space-y-8 relative before:absolute before:inset-0 before:right-auto before:left-3.5 before:w-px before:bg-slate-800">
                
                <!-- Role 1: Southard Homes -->
                <div class="relative pl-8 group">
                    <div class="absolute left-2 top-1.5 w-3 h-3 bg-cyan-500 rounded-full border-4 border-slate-900 group-hover:scale-125 transition-transform duration-200"></div>
                    <div class="bg-black/50 border border-slate-800/90 p-6 rounded-xl backdrop-blur-sm shadow-md">
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 mb-4">
                            <div>
                                <h3 class="text-lg font-semibold text-white">Web Developer</h3>
                                <p class="text-sm text-slate-400">Southard Homes, LLC — Terre Haute, IN</p>
                            </div>
                            <span class="text-xs font-mono bg-slate-900 border border-slate-800 text-cyan-400 px-2.5 py-1 rounded-full self-start sm:self-center">
                                2026 – Present
                            </span>
                        </div>
                        <ul class="text-slate-300 text-sm space-y-2 list-disc list-inside mb-4 leading-relaxed">
                            <li>Design, develop, deploy, and maintain production websites for multiple business clients using Astro, Tailwind CSS, TypeScript, GitHub, and Netlify.</li>
                            <li>Manage GitHub repositories, production deployments, hosting platforms, DNS configuration, and release management for multiple client websites.</li>
                            <li>Collaborate directly with business owners to gather requirements, translate feedback into technical solutions, and deliver website updates.</li>
                        </ul>

                        <!-- Highlighted Client Projects Sub-grid -->
                        <div class="border-t border-slate-800/60 pt-4 mt-4">
                            <h4 class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Production Deployments</h4>
                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                                <div class="bg-slate-900/40 border border-slate-800/60 p-3 rounded-lg">
                                    <p class="text-xs font-medium text-white">Southard Homes</p>
                                    <p class="text-[11px] text-slate-400 font-mono mt-1">Astro • Tailwind • TS</p>
                                </div>
                                <div class="bg-slate-900/40 border border-slate-800/60 p-3 rounded-lg">
                                    <p class="text-xs font-medium text-white">Quality Electric of IN</p>
                                    <p class="text-[11px] text-slate-400 font-mono mt-1">Astro • Tailwind • TS</p>
                                </div>
                                <div class="bg-slate-900/40 border border-slate-800/60 p-3 rounded-lg">
                                    <p class="text-xs font-medium text-white">Quality Landscape</p>
                                    <p class="text-[11px] text-slate-400 font-mono mt-1">Launching Soon</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Role 2: Jedele Enterprises -->
                <div class="relative pl-8 group">
                    <div class="absolute left-2 top-1.5 w-3 h-3 bg-slate-700 rounded-full border-4 border-slate-900 group-hover:bg-cyan-600 group-hover:scale-125 transition-all duration-200"></div>
                    <div class="bg-black/50 border border-slate-800/90 p-6 rounded-xl backdrop-blur-sm shadow-md">
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 mb-4">
                            <div>
                                <h3 class="text-lg font-semibold text-white">Operations Technology Professional (OTP 2)</h3>
                                <p class="text-sm text-slate-400">Jedele Enterprises — Brazil, IN</p>
                            </div>
                            <span class="text-xs font-mono bg-slate-900 border border-slate-800 text-slate-400 px-2.5 py-1 rounded-full self-start sm:self-center">
                                2019 – 2026
                            </span>
                        </div>
                        <ul class="text-slate-300 text-sm space-y-2 list-disc list-inside leading-relaxed">
                            <li>Supported business-critical systems with 99%+ uptime, reducing incident resolution time by over 1 hour.</li>
                            <li>Diagnosed and resolved complex software, hardware, and integration issues in high-pressure environments.</li>
                            <li>Performed root cause analysis and contributed to long-term system reliability improvements.</li>
                            <li>Mentored team members and acted as a technical liaison to non-technical stakeholders.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Education Section -->
        <section class="mb-12">
            <h2 class="text-2xl font-light text-white mb-6 tracking-tight">
                Education
            </h2>
            <div class="bg-black/50 border border-slate-800/90 p-6 rounded-xl backdrop-blur-sm flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                <div>
                    <h3 class="text-lg font-semibold text-white">Bachelor of Science in Computer Information Systems</h3>
                    <p class="text-sm text-slate-400">DeVry University — Federal Way, WA</p>
                </div>
                <div class="bg-slate-900/80 border border-slate-800 px-4 py-2 rounded-xl text-center self-stretch sm:self-auto">
                    <p class="text-xs text-slate-400 uppercase tracking-wider font-medium">GPA</p>
                    <p class="text-lg font-bold text-cyan-400 font-mono">3.76</p>
                </div>
            </div>
        </section>

        <!-- Call to Action Button to match Home page style -->
        <div class="text-center mt-16">
            <a 
                href="/projects" 
                class="inline-block bg-cyan-600 hover:bg-cyan-500 
                text-white text-sm font-medium px-6 py-3 rounded-lg hover:scale-110
                transition-all duration-400 text-center shadow-md shadow-cyan-950/20"
            >
                View My Projects
            </a>
        </div>

        <Footer />
    </div>
</Layout>