---
const pathname = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/skills", label: "Skills" },
  { href: "/contact", label: "Contact" },
];
---

<header class="bg-black/50 backdrop-blur-md text-slate-200 font-sans border-b border-slate-800/40 sticky top-0 z-50">
    <nav class="flex flex-wrap items-center justify-between py-4 px-6 max-w-7xl mx-auto">
        <div class="text-[1.1rem] font-medium tracking-wide">
            <a href="/" class="text-white hover:text-cyan-400 transition-colors duration-200 no-underline">
                Kevin "Anthony" Felker
            </a>
        </div>

        <input type="checkbox" id="menu-toggle" class="peer hidden" />

        <label 
            for="menu-toggle" 
            class="flex flex-col gap-1.5 cursor-pointer md:hidden 
                   peer-checked:[&>span:nth-child(1)]:translate-y-2 peer-checked:[&>span:nth-child(1)]:rotate-45
                   peer-checked:[&>span:nth-child(2)]:opacity-0
                   peer-checked:[&>span:nth-child(3)]:-translate-y-2 peer-checked:[&>span:nth-child(3)]:-rotate-45"
        >
            <span class="w-6 h-0.5 bg-white transition-all duration-300"></span>
            <span class="w-6 h-0.5 bg-white transition-all duration-300"></span>
            <span class="w-6 h-0.5 bg-white transition-all duration-300"></span>
        </label>

        <ul class="flex flex-col w-full list-none m-0 p-0 max-h-0 opacity-0 overflow-hidden 
                   transition-all duration-400 ease-in-out
                   peer-checked:max-h-64 peer-checked:opacity-100 peer-checked:py-4
                   md:flex md:flex-row md:w-auto md:max-h-none md:opacity-100 md:overflow-visible md:gap-6 md:p-0">
            
            {navLinks.map(({ href, label }) => {
                const isActive = href === "/" 
                    ? pathname === "/" 
                    : pathname.startsWith(href);

                return (
                    <li class="py-2 px-4 md:p-0">
                        <a 
                            href={href} 
                            class={`no-underline transition-colors duration-200 text-sm tracking-wide
                                ${isActive 
                                    ? 'text-cyan-400 font-semibold' 
                                    : 'text-slate-300 hover:text-white' 
                                }`}
                        >
                            {label}
                        </a>
                    </li>
                );
            })}
        </ul>
    </nav>
</header>