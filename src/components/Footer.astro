---
import { Icon } from 'astro-icon/components';
---

<footer class="mt-16 border-t border-slate-800/60 py-8">
    <div class="max-w-7xl mx-auto px-4 text-center text-sm text-slate-400 space-y-4">
        <p>© 2026 Kevin "Anthony" Felker</p>

        <div class="flex justify-center gap-6">
            <a
                href="https://github.com/felker12"
                target="_blank"
                rel="noopener noreferrer"
                title="GitHub"
                class="text-slate-400 hover:text-cyan-400 transition-all duration-200 hover:scale-110"
            >
                <Icon name="mdi:github" class="w-6 h-6" />
            </a>

            <a
                href="https://www.linkedin.com/in/anthonyfelker/"
                target="_blank"
                rel="noopener noreferrer"
                title="LinkedIn"
                class="text-slate-400 hover:text-cyan-400 transition-all duration-200 hover:scale-110"
            >
                <Icon name="mdi:linkedin" class="w-6 h-6" />
            </a>

            <a
                href="/contact"
                title="Contact"
                class="text-slate-400 hover:text-cyan-400 transition-all duration-200 hover:scale-110"
            >
                <Icon name="mdi:email-outline" class="w-6 h-6" />
            </a>
        </div>
    </div>
</footer>